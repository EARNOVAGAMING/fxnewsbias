{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fxnewsbias",
  "compatibility_date": "2026-04-29",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "triggers": {
    "crons": [
      "0 */3 * * *",
      "*/15 * * * *",
      "0 0 * * *",
      "0 6 * * *",
      "0 12 * * *"
    ]
  }
}
