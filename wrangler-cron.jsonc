{
  "name": "fxnewsbias-cron",
  "main": "/root/fxnewsbias/cf/cron_worker.js",
  "compatibility_date": "2026-04-29",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": [
      "*/15 * * * *",   // prices only (self-heal removed)
      "0 */3 * * *",    // sentiment → pairSEO → currencySEO → cleanup (sequential)
      "0 0 * * *",      // ASEAN session insight
      "0 6 * * *",      // London session insight
      "0 12 * * *"      // NY session insight
    ]
  }
}
