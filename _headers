# Cache static assets aggressively (1 year)
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.ico
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Cache JS/CSS for 1 day (so we can push updates without long TTL pain)
/*.js
  Cache-Control: public, max-age=86400, must-revalidate
/*.css
  Cache-Control: public, max-age=86400, must-revalidate

# HTML pages — short cache so users get updates fast
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Directory-style paths (no file extension) — force no edge cache so
# updates show immediately. CF Pages default would over-cache these.
/
  Cache-Control: public, max-age=0, must-revalidate, s-maxage=0
  CDN-Cache-Control: no-store
/insight/
  Cache-Control: public, max-age=0, must-revalidate, s-maxage=0
  CDN-Cache-Control: no-store

# Security headers (also helps Best Practices score)
# HSTS: tells browsers + Google "this domain is HTTPS only, forever".
# Strongest possible signal that http:// version should never be indexed.
# 6-month max-age, includeSubDomains, preload-eligible.
/*
  Strict-Transport-Security: max-age=15768000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
